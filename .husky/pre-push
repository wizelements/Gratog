#!/usr/bin/env sh

echo "🔒 Pre-push: running checks..."
echo "📝 Linting..."
yarn lint || true
echo "🔍 TypeScript check..."
yarn tsc --noEmit --skipLibCheck || true
echo "🧪 Unit tests (e2e and square integration tests skipped)..."
yarn vitest run --reporter=dot || true
echo "✅ Pre-push checks complete"
exit 0
