#!/usr/bin/env sh

echo "🔒 Pre-push: running comprehensive checks..."

# TypeScript check - FAIL if errors
echo "🔍 TypeScript check..."
yarn tsc --noEmit --skipLibCheck
if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors found. Fix them before pushing."
  exit 1
fi

# Linting - FAIL if errors
echo "📝 Linting..."
yarn lint
if [ $? -ne 0 ]; then
  echo "❌ Linting errors found. Fix them before pushing."
  exit 1
fi

# Unit tests - FAIL if errors (but not e2e/integration)
echo "🧪 Running unit tests..."
yarn vitest run --reporter=dot
if [ $? -ne 0 ]; then
  echo "❌ Unit test failures found. Fix them before pushing."
  exit 1
fi

# Smoke tests - Critical path validation
echo "🚨 Running smoke tests..."
yarn vitest run tests/smoke.test.ts tests/hydration-safety.test.ts --reporter=dot 2>/dev/null
if [ $? -ne 0 ]; then
  echo "❌ Smoke test failures - potential production breakage!"
  exit 1
fi

# Pre-deployment validation
echo "🔍 Running deployment validation..."
node scripts/validate-deployment.js
if [ $? -ne 0 ]; then
  echo "❌ Deployment validation failed. Fix errors before pushing."
  exit 1
fi

echo "✅ All pre-push checks passed - safe to deploy!"
exit 0
