{
  "name": "taste-of-gratitude",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=2048' next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "next lint",
    "fix:deployment": "node scripts/fix-deployment-issues.js",
    "postinstall": "node scripts/fix-deployment-issues.js || true",
    "create:test-user": "node scripts/create-test-user.js",
    "typecheck": "tsc --noEmit --skipLibCheck || echo 'TypeScript errors found but continuing...'",
    "test:unit": "vitest run --coverage --reporter=dot",
    "test:api": "cross-env NODE_ENV=test vitest run --config vitest.integration.config.ts --reporter=dot",
    "test:e2e:headless": "playwright test --reporter=line",
    "test:e2e:smoke": "playwright test -g @smoke --reporter=line",
    "test:k6": "k6 run e2e/k6/smoke.js",
    "lighthouse": "lhci autorun",
    "lighthouse:ci": "lhci autorun --config=lighthouserc.js",
    "preverify": "npm run lint",
    "verify": "npm run test:unit && npm run test:e2e:headless",
    "verify:ci": "npm run preverify && npm run verify",
    "verify:full": "npm run lint && npm run typecheck && npm run test:unit && npm run test:e2e:headless && npm run test:k6",
    "postverify": "echo '✅ All tests passed'",
    "prepare": "husky",
    "vorax": "node .vorax/vorax-cli.js hunt",
    "vorax:quick": "node .vorax/vorax-cli.js quick",
    "vorax:nano": "node .vorax/vorax-cli.js nano",
    "vorax:watch": "node .vorax/vorax-cli.js watch",
    "vorax:status": "node .vorax/vorax-cli.js status",
    "vorax:report": "node .vorax/vorax-cli.js report",
    "validate": "node scripts/validate-deployment.js",
    "standby": "node scripts/standby-monitor.js",
    "diagnose": "node scripts/diagnose-integration-tests.js",
    "deploy:monitor": "node scripts/deploy-monitor-simple.js",
    "test:smoke": "vitest run tests/smoke.test.ts tests/hydration-safety.test.ts --reporter=verbose",
    "predeploy": "npm run validate && npm run test:smoke && npm run build"
  },
  "dependencies": {
    "@google/model-viewer": "^4.1.0",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-aspect-ratio": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/nextjs": "^10.26.0",
    "@stripe/stripe-js": "^4.10.0",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "framer-motion": "^12.23.24",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "mongodb": "^6.11.0",
    "next": "15.5.9",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.284.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-confetti": "^6.1.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "redis": "^5.9.0",
    "resend": "^6.5.2",
    "sharp": "^0.33.5",
    "sonner": "^2.0.7",
    "square": "43.2.0",
    "stripe": "^17.5.0",
    "swr": "^2.3.6",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.181.2",
    "twilio": "^5.3.5",
    "uuid": "^13.0.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@lhci/cli": "0.12.x",
    "@playwright/test": "^1.47.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.21",
    "critters": "^0.0.25",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "husky": "^9.0.0",
    "postcss": "^8.5.6",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vitest": "^2.0.0"
  }
}
