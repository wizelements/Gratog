{
  "crons": [
    {
      "path": "/api/cron/hourly-reindex",
      "schedule": "0 * * * *"
    }
  ],
  "functions": {
    "app/api/v1/admin/reindex/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/hourly-reindex/route.ts": {
      "maxDuration": 300
    },
    "app/lib/crawler.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/v1/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://tasteofgratitude.shop"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/health",
      "destination": "/api/v1/health"
    }
  ],
  "redirects": [
    {
      "source": "/health",
      "destination": "/api/v1/health",
      "permanent": false
    }
  ]
}
