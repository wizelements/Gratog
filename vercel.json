{
  "crons": [
    {
      "path": "/api/cron/health-check",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/scheduled-campaigns",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/pickup-reminders",
      "schedule": "0 9 * * 5"
    },
    {
      "path": "/api/cron/morning-reminders",
      "schedule": "0 8 * * 6"
    },
    {
      "path": "/api/quiz/email-scheduler",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/subscription-reminders",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/cleanup-abandoned-orders",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/missed-pickup",
      "schedule": "0 18 * * 6"
    }
  ],
  "functions": {
    "app/api/**/*.{ts,js}": {
      "maxDuration": 30
    },
    "app/api/orders/create/route.js": {
      "maxDuration": 60
    },
    "app/api/payments/route.ts": {
      "maxDuration": 60
    },
    "app/api/checkout/route.ts": {
      "maxDuration": 60
    },
    "app/api/square-webhook/route.js": {
      "maxDuration": 60
    },
    "app/api/subscriptions/**/route.js": {
      "maxDuration": 60
    },
    "app/api/subscriptions/webhook/route.js": {
      "maxDuration": 60
    }
  },
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://tasteofgratitude.shop"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self), payment=(self)"
        }
      ]
    },
    {
      "source": "/:path*.ico",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.jpeg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.gif",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.avif",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.woff",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.woff2",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/v1/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://tasteofgratitude.shop"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/health",
      "destination": "/api/v1/health",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "gratog.vercel.app"
        }
      ],
      "destination": "https://tasteofgratitude.shop/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "taste-og.vercel.app"
        }
      ],
      "destination": "https://tasteofgratitude.shop/:path*",
      "permanent": true
    }
  ]
}
