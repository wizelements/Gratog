TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (Email) - Optional  
# Leave blank to use mock email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@tasteofgratitude.com

# Admin
JWT_SECRET=taste-of-gratitude-secret-key-2025
