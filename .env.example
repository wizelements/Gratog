# Database
MONGO_URL=mongodb://localhost:27017
DB_NAME=taste_of_gratitude

# Site
NEXT_PUBLIC_BASE_URL=https://taste-ecommerce.preview.emergentagent.com
NEXT_PUBLIC_SITE_NAME=Taste of Gratitude
NEXT_PUBLIC_SITE_URL=https://taste-ecommerce.preview.emergentagent.com
CORS_ORIGINS=*

# Stripe Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
