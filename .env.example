# ========================================
# GRATOG - Taste of Gratitude
# Environment Configuration Template
# ========================================

# Application
NEXT_PUBLIC_APP_URL=https://tasteofgratitude.shop
NODE_ENV=production

# ========================================
# PAYMENTS - Square
# ========================================
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_APPLICATION_ID=your_square_application_id
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=production
# SQUARE_ENVIRONMENT=sandbox  # For testing

# ========================================
# EMAIL - Resend
# ========================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@tasteofgratitude.shop

# ========================================
# SMS - Twilio
# ========================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ========================================
# DATABASE - MongoDB
# ========================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gratog
DB_NAME=gratog

# ========================================
# CACHE - Redis
# ========================================
REDIS_URL=redis://default:password@localhost:6379/0

# ========================================
# ERROR TRACKING - Sentry
# ========================================
NEXT_PUBLIC_SENTRY_DSN=https://your@sentry.io/project-id
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ========================================
# THIRD PARTY INTEGRATIONS
# ========================================
# Instagram API (if configured)
INSTAGRAM_ACCESS_TOKEN=optional_instagram_token

# Analytics
NEXT_PUBLIC_GTAG_ID=G_ANALYTICS_ID

# ========================================
# CRON JOB CONFIGURATION
# ========================================
# These cron jobs are configured in vercel.json:
# - Health check (every 5 minutes)
# - Scheduled campaigns (every 5 minutes)
# - Pickup reminders (Fridays at 9 AM)
# - Morning reminders (Saturdays at 8 AM)
# - Email scheduler (hourly)

CRON_SECRET=your_cron_secret_for_verification

# ========================================
# STRIPE (Deprecation Notice)
# ========================================
# NOTE: Deprecated in favor of Square
# These are kept for backward compatibility only
STRIPE_PUBLIC_KEY=pk_live_your_stripe_key
STRIPE_SECRET_KEY=sk_live_your_stripe_key

# ========================================
# SENDGRID (Deprecation Notice)
# ========================================
# NOTE: Deprecated in favor of Resend
SENDGRID_API_KEY=deprecated_use_resend_instead

# ========================================
# DEVELOPMENT / STAGING
# ========================================
# Only needed for non-production environments
DEBUG=false
LOG_LEVEL=info
NEXT_PUBLIC_DEBUG_MODE=false
