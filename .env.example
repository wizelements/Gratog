# ========================================
# GRATOG - Taste of Gratitude
# Environment Configuration Template
# ========================================

# Application
NEXT_PUBLIC_APP_URL=https://tasteofgratitude.shop
NEXT_PUBLIC_BASE_URL=https://tasteofgratitude.shop
CONTACT_EMAIL=hello@tasteofgratitude.shop
SUPPORT_EMAIL=hello@tasteofgratitude.shop
CORS_ORIGINS=https://tasteofgratitude.shop
NODE_ENV=production

# ========================================
# PAYMENTS - Square
# ========================================
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_APPLICATION_ID=your_square_application_id
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=production
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
SQUARE_SUBSCRIPTIONS_WEBHOOK_URL=https://tasteofgratitude.shop/api/subscriptions/webhook
# SQUARE_ENVIRONMENT=sandbox  # For testing

# ========================================
# EMAIL - Resend
# ========================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@tasteofgratitude.shop
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret

# ========================================
# SMS - Twilio
# ========================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ========================================
# DATABASE - MongoDB
# ========================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gratog
DB_NAME=gratog

# ========================================
# CACHE - Redis
# ========================================
REDIS_URL=redis://default:password@localhost:6379/0
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ========================================
# ERROR TRACKING - Sentry
# ========================================
NEXT_PUBLIC_SENTRY_DSN=https://your@sentry.io/project-id
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ========================================
# THIRD PARTY INTEGRATIONS
# ========================================
# Instagram API (if configured)
INSTAGRAM_ACCESS_TOKEN=optional_instagram_token

# Analytics
NEXT_PUBLIC_GTAG_ID=G_ANALYTICS_ID
NEXT_PUBLIC_POSTHOG_KEY=optional_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ========================================
# PASSIVE REVENUE FUNNEL (phases 1-6)
# ========================================
# Admin phone for SMS fallback notifications / win-back sends
ADMIN_PHONE=+14046633225

# Admin API token for cron/manual automation routes
ADMIN_API_TOKEN=your_admin_api_token

# Weekly menu warm cron + admin manual warm route auth
WEEKLY_WARM_CRON_SECRET=your_weekly_warm_secret

# Subscription box: Stripe placeholders (optional; Square primary)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_GRATITUDE_BOX_PRICE_ID=price_your_gratitude_box_product

# Win-back / retention automation
WINBACK_DAYS_INACTIVE=21
WINBACK_COUPON_CODE=WELCOME15

# Delivery minimum for preorder local delivery toggle
PREORDER_DELIVERY_MIN_CENTS=6000

# ========================================
# CRON JOB CONFIGURATION
# ========================================
# These cron jobs are configured in vercel.json:
# - Health check (every 5 minutes)
# - Scheduled campaigns (every 5 minutes)
# - Pickup reminders (Fridays at 9 AM)
# - Morning reminders (Saturdays at 8 AM)
# - Email scheduler (hourly)
# - Subscription reminders (daily at 15:00 UTC)
# - Cleanup abandoned orders (every 2 hours)
# - Missed pickup follow-up (Saturday 18:00 UTC)

CRON_SECRET=your_cron_secret_for_verification

# Feature flags
FEATURE_SUBSCRIPTIONS_ENABLED=true

# ========================================
# Stripe removed — Square is primary processor
# ========================================

# ========================================
# AUTHENTICATION
# ========================================
JWT_SECRET=your-jwt-secret-at-least-32-characters
ADMIN_SETUP_SECRET=your-admin-setup-secret
ADMIN_DEFAULT_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=your-admin-password

# Sync Secrets
SYNC_SECRET=your-sync-secret

# ========================================
# DEVELOPMENT / STAGING
# ========================================
# Only needed for non-production environments
DEBUG=false
LOG_LEVEL=info
NEXT_PUBLIC_DEBUG_MODE=false
