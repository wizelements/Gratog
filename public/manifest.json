{
  "name": "Taste of Gratitude",
  "short_name": "Gratog",
  "description": "Premium e-commerce platform for gratitude-based gifts",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#ffffff",
  "theme_color": "#1f2937",
  "icons": [
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-maskable-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icon-maskable-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot-540x720.svg",
      "sizes": "540x720",
      "type": "image/svg+xml",
      "form_factor": "narrow",
      "label": "Gratitude Gift Shopping"
    },
    {
      "src": "/screenshots/screenshot-1280x720.svg",
      "sizes": "1280x720",
      "type": "image/svg+xml",
      "form_factor": "wide",
      "label": "Gratitude Gift Shopping"
    }
  ],
  "categories": ["shopping", "lifestyle"],
  "protocol_handlers": [
    {
      "protocol": "web+gratog",
      "url": "/?product=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/open-order",
      "accept": {
        "application/json": [".json"]
      },
      "icons": [
        {
          "src": "/icons/icon-192x192.svg",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "shortcuts": [
    {
      "name": "Browse Products",
      "short_name": "Shop",
      "description": "Browse our gratitude gift collection",
      "url": "/catalog?utm_source=pwa_shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-shop-192x192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "My Orders",
      "short_name": "Orders",
      "description": "View your orders",
      "url": "/profile/orders?utm_source=pwa_shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-orders-192x192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "prefer_related_applications": false
}
